{
  "name": "Finance: Gateway Sync",
  "nodes": [
    {
      "parameters": {"rule": {"interval": [{"field": "hours", "triggerAtMinute": 0}]}},
      "name": "Daily Sync",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [200, 300]
    },
    {
      "parameters": {"resource": "balanceTransaction", "operation": "getAll", "limit": 100},
      "name": "Stripe: Get Trans",
      "type": "n8n-nodes-base.stripe",
      "typeVersion": 1,
      "position": [420, 300]
    },
    {
      "parameters": {"operation": "append", "sheetId": "finance_sheet_id", "options": {}},
      "name": "Google Sheets: Log",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 3,
      "position": [640, 300]
    }
  ],
  "connections": {
    "Daily Sync": {"main": [[{"node": "Stripe: Get Trans", "type": "main", "index": 0}]]},
    "Stripe: Get Trans": {"main": [[{"node": "Google Sheets: Log", "type": "main", "index": 0}]]}
  },
  "active": false,
  "settings": {}
}
